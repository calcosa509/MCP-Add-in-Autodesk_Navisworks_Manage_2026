{
  "dxt_version": "0.1",
  "name": "navisworks-mcp-coordination",
  "version": "1.0.0",
  "description": "Navisworks Manage 2026 MCP – Coordination, clash detection and model analysis for construction projects.",
  "author": {
    "name": "Calvens Joseph",
    "email": "contact@calvensjoseph.com",
    "url": "https://github.com/calcosa509"
  },
  "license": "MIT",
  "homepage": "https://github.com/calcosa509/MCP-Add-in-Autodesk_Navisworks_Manage_2026",
  "documentation": "https://github.com/calcosa509/MCP-Add-in-Autodesk_Navisworks_Manage_2026",
  "support": "https://github.com/calcosa509/MCP-Add-in-Autodesk_Navisworks_Manage_2026",
  "icon": "icon.png",

  "server": {
    "type": "node",
    "entry_point": "server/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/server/index.js"],
      "env": {
        "NAVISWORKS_API_PORT": "${user_config.api_port}"
      }
    }
  },

  "tools": [
    {
      "name": "get_model_info",
      "description": "Get basic information about the active Navisworks model.",
      "input_schema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "list_items_by_discipline",
      "description": "List model items grouped by discipline (Architecture, Structure, MEP).",
      "input_schema": {
        "type": "object",
        "properties": {
          "discipline": {
            "type": "string",
            "enum": ["Architecture", "Structure", "MEP"]
          }
        },
        "required": ["discipline"]
      }
    },
    {
      "name": "get_item_properties",
      "description": "Retrieve properties of a specific model item.",
      "input_schema": {
        "type": "object",
        "properties": {
          "item_id": {
            "type": "string",
            "description": "Unique identifier of the Navisworks model item."
          }
        },
        "required": ["item_id"]
      }
    },
    {
      "name": "run_clash_test",
      "description": "Run a predefined clash test between two disciplines.",
      "input_schema": {
        "type": "object",
        "properties": {
          "discipline_a": {
            "type": "string",
            "enum": ["Architecture", "Structure", "MEP"]
          },
          "discipline_b": {
            "type": "string",
            "enum": ["Architecture", "Structure", "MEP"]
          }
        },
        "required": ["discipline_a", "discipline_b"]
      }
    },
    {
      "name": "get_clash_results",
      "description": "Retrieve all detected clashes from the last clash test.",
      "input_schema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "get_critical_clashes",
      "description": "Retrieve only critical clashes based on severity and tolerance.",
      "input_schema": {
        "type": "object",
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["High", "Critical"]
          }
        },
        "required": ["severity"]
      }
    },
    {
      "name": "summarize_clashes_for_meeting",
      "description": "Generate a coordination-friendly summary of clashes for meetings.",
      "input_schema": {
        "type": "object",
        "properties": {},
        "required": []
      }
    },
    {
      "name": "compare_clash_reports",
      "description": "Compare two clash reports and identify progress or regressions.",
      "input_schema": {
        "type": "object",
        "properties": {
          "previous_report_id": {
            "type": "string"
          },
          "current_report_id": {
            "type": "string"
          }
        },
        "required": ["previous_report_id", "current_report_id"]
      }
    }
  ]
}
